name: Rank predictions

on:
  workflow_run:
    workflows: ["Generate predictions"]
    types: [completed]
  workflow_dispatch:

jobs:
  rank:
    if: ${{ github.event_name == 'workflow_dispatch' || github.event.workflow_run.conclusion == 'success' }}
    runs-on: ubuntu-latest

    permissions:
      actions: read
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v5

      - name: Download prediction artifacts
        uses: dawidd6/action-download-artifact@v9
        with:
          workflow: generate_predictions.yml
          name: today-predictions-files
          path: .

      - name: Show downloaded files
        run: |
          echo "Root:"
          ls -lah
          echo ""
          echo "build_predictions:"
          ls -lah build_predictions || true

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          if [ -f requirements.txt ]; then
            pip install -r requirements.txt
          else
            pip install openai
          fi

      - name: Run ranking
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
        run: |
          python scripts/rank_predictions.py

      - name: Upload ranking output
        uses: actions/upload-artifact@v4
        with:
          name: daily-top10-output
          path: output/

      - name: Commit latest output
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add output/
          git diff --cached --quiet || git commit -m "Update daily top10"
          git push
